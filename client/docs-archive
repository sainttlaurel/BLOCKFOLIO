## Common Use Cases

### 1. Conditional Feature Usage

```javascript
import { checkFeatureSupport } from './utils/browserDetection';

function MyComponent() {
  const features = checkFeatureSupport();
  
  return (
    <div className={features.backdropFilter ? 'glass-card' : 'solid-card'}>
      {/* Content */}
    </div>
  );
}
```

### 2. Browser-Specific Styling

```javascript
import { detectBrowser } from './utils/browserDetection';

function MyComponent() {
  const browser = detectBrowser();
  
  return (
    <div className={`card ${browser.name.toLowerCase()}-specific`}>
      {/* Content */}
    </div>
  );
}
```

### 3. Performance Optimization

```javascript
import { getPerformanceRecommendations } from './utils/browserDetection';

function ChartComponent() {
  const recommendations = getPerformanceRecommendations();
  
  const chartOptions = {
    animation: !recommendations.simplifyAnimations,
    // Other options
  };
  
  return <Chart options={chartOptions} />;
}
```

### 4. Mobile Detection

```javascript
import { detectBrowser } from './utils/browserDetection';

function Navigation() {
  const browser = detectBrowser();
  
  return browser.isMobile ? <MobileNav /> : <DesktopNav />;
}
```

