## Quick Integration

### 1. Initialize Browser Detection

Add to your main `App.js` or `index.js`:

```javascript
import { initBrowserCompatibility } from './utils/browserDetection';

function App() {
  useEffect(() => {
    // Initialize browser compatibility check
    const compatibility = initBrowserCompatibility();
    
    // Logs browser info to console in development
    // Adds CSS classes to body element
    // Shows update notice if browser is outdated
  }, []);

  return (
    // Your app content
  );
}
```

### 2. Show Compatibility Notice (Optional)

```javascript
import { BrowserCompatibilityNotice } from './examples/BrowserCompatibilityExample';

function App() {
  return (
    <>
      <BrowserCompatibilityNotice />
      {/* Your app content */}
    </>
  );
}
```

### 3. Apply Performance Optimizations (Optional)

```javascript
import { PerformanceOptimizations } from './examples/BrowserCompatibilityExample';

function App() {
  return (
    <PerformanceOptimizations>
      {/* Your app content */}
    </PerformanceOptimizations>
  );
}
```

